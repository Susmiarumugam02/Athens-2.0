# Environment Variables Template
# Copy this file to .env.local for local development

# API Base URL
VITE_API_URL=http://localhost:8004

# Development Bypass Flags
# WARNING: These should NEVER be enabled in production

# Bypass induction training requirement (development only)
# Set to 'true' to skip induction attendance requirement
# MUST be 'false' or absent in production builds
VITE_BYPASS_INDUCTION=false
